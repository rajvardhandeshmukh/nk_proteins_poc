[Unit]
Description=NK Proteins CMD CoPilot Streamlit App
After=network.target

[Service]
User=your_username
Group=your_group
WorkingDirectory=/home/your_username/nk_proteins_poc
ExecStart=/home/your_username/nk_proteins_poc/venv/bin/streamlit run app.py --server.port=8501 --server.address=0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
